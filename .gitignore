# --- Data (regenerated by the pipeline; never committed) ---
/data/raw/*
/data/interim/*
/data/processed/*
/data/gold/*
!**/.gitkeep
*.db
*.sqlite
*.sqlite3

# --- Local scratch & vendored material (not part of the deliverable) ---
/_local/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.Python

# --- Virtual environments ---
.venv/
venv/
env/

# --- Tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Jupyter scratch notebooks ---
notebooks/asd.ipynb

# --- Secrets / environment ---
.env
.env.*
!.env.example

# --- IDE / OS ---
.idea/
.vs/
*.code-workspace
.DS_Store
Thumbs.db
